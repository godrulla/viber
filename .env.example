# Viber Configuration Template
# Copy to .env and customize for your environment

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NODE_ENV=development
PORT=3000
HOST=localhost

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# MongoDB
MONGODB_URI=mongodb://localhost:27017/viber_development
DB_MAX_POOL_SIZE=10
DB_SELECTION_TIMEOUT=5000
DB_SOCKET_TIMEOUT=45000

# Redis (for sessions and caching)
REDIS_URI=redis://localhost:6379

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# JWT Secret - CRITICAL: Change in production!
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000

# ===========================================
# CORS SETTINGS
# ===========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL=debug
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
LOG_CONSOLE_ENABLED=true

# ===========================================
# FEATURE FLAGS
# ===========================================
FEATURE_AI_INTEGRATION=false
FEATURE_MESSAGE_ENCRYPTION=true
FEATURE_FILE_SHARING=true
FEATURE_VOICE_MESSAGES=false
FEATURE_VIDEO_CHAT=false

# ===========================================
# EXTERNAL SERVICES
# ===========================================
# OpenAI (for AI features)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000

# AWS (for file storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=viber-files-bucket

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
# These settings only apply in development mode

# Debug flags
DEBUG_SQL=false
DEBUG_SOCKET=false
DEBUG_AUTH=false

# Mock services (useful for testing)
MOCK_EXTERNAL_SERVICES=false
MOCK_EMAIL_SERVICE=false
MOCK_SMS_SERVICE=false